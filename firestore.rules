rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny rule
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Fiscal Profiles rules
    // Path: fiscalProfiles/{userId}
    match /fiscalProfiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Tickets rules
    // Path: tickets/{ticketId}
    match /tickets/{ticketId} {
      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Connectors rules
    // Path: connectors/{connectorId}
    match /connectors/{connectorId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
        && (request.resource.data.userId == request.auth.uid || request.resource.data.userId == "system");
      allow update: if isSignedIn() 
        && (resource.data.userId == request.auth.uid || resource.data.userId == "system")
        && (request.resource.data.userId == request.auth.uid || request.resource.data.userId == "system");
      allow delete: if isSignedIn() 
        && (resource.data.userId == request.auth.uid);
    }

    // Invoices rules
    // Path: invoices/{invoiceId}
    match /invoices/{invoiceId} {
      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
